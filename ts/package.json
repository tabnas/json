{
  "name": "@tabnas/json",
  "version": "0.3.2",
  "main": "dist/json.js",
  "type": "commonjs",
  "types": "dist/json.d.ts",
  "description": "A standard JSON parser (RFC 8259).",
  "keywords": [
    "json",
    "parser",
    "rfc8259",
    "ecma-404"
  ],
  "author": "tabnas",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc --build src",
    "watch": "tsc --build src -w",
    "clean": "rm -rf node_modules dist package-lock.json",
    "test": "npm run build && node --enable-source-maps --test test/**/*.test.js",
    "coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-include=dist/json.js --test-coverage-include=dist/json-cli.js --test-coverage-lines=0.95 test/**/*.test.js"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "bin": {
    "tabnas-json": "bin/json"
  },
  "exports": {
    ".": "./dist/json.js"
  },
  "devDependencies": {
    "@tabnas/debug": "*",
    "@tabnas/parser": "*",
    "@tabnas/railroad": "*",
    "@types/node": "20.x",
    "typescript": "5.x"
  },
  "peerDependencies": {
    "@tabnas/parser": ">=0"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/tabnas/json.git",
    "directory": "ts"
  }
}
